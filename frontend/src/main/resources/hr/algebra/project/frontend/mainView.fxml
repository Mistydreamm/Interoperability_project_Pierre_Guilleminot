<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.project.frontend.controller.MainViewController"
      alignment="CENTER" spacing="10" prefHeight="700" prefWidth="900">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <children>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchIdTextField" promptText="ID" prefWidth="60.0"/>
            <Button onAction="#searchRecordById" text="Search by ID"/>
            <Button fx:id="showAddFormButton" onAction="#showAddForm" text="Add New Personal Record"/>
            <Button fx:id="showEditFormButton" onAction="#showEditForm" text="Edit Selected Record"/>
            <Button fx:id="deleteRecordButton" onAction="#deletePersonalRecord" text="Delete Selected Record"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleLogout" text="Logout" style="-fx-background-color: #ff4444; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="recordsTableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="liftTypeColumn" text="Lift Type" prefWidth="100"/>
                <TableColumn fx:id="weightColumn" text="Weight lifted(kg)" prefWidth="100"/>
                <TableColumn fx:id="repsColumn" text="Reps" prefWidth="50"/>
                <TableColumn fx:id="setsColumn" text="Sets" prefWidth="50"/>
                <TableColumn fx:id="rpeColumn" text="RPE" prefWidth="50"/>
                <TableColumn fx:id="bodyweightColumn" text="Bodyweight(kg)" prefWidth="100"/>
                <TableColumn fx:id="gymLocationColumn" text="Gym Location" prefWidth="100"/>
                <TableColumn fx:id="milestoneColumn" text="Milestone" prefWidth="50"/>
                <TableColumn fx:id="equipmentColumn" text="Equipment" prefWidth="100"/>
                <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
                <TableColumn fx:id="addedByColumn" text="Added By" prefWidth="100"/>
                <TableColumn fx:id="notesColumn" text="Notes" prefWidth="200"/>
            </columns>
        </TableView>

        <VBox fx:id="postFormVBox" spacing="10" alignment="CENTER"
              style="-fx-border-color: lightgray; -fx-border-width: 1; -fx-border-radius: 5; -fx-padding: 10;"
              visible="false" managed="false">

            <HBox spacing="10" alignment="CENTER">
                <ChoiceBox fx:id="liftTypeChoiceBox" prefWidth="150"/>
                <ChoiceBox fx:id="muscleGroupChoiceBox" prefWidth="150"/>
                <TextField fx:id="equipmentTextField" promptText="Equipment" prefWidth="150"/>
                <TextField fx:id="gymLocationTextField" promptText="Gym Location" prefWidth="150"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="weightTextField" promptText="Weight (kg)" prefWidth="100"/>
                <TextField fx:id="repsTextField" promptText="Reps" prefWidth="80"/>
                <TextField fx:id="setsTextField" promptText="Sets" prefWidth="80"/>
                <TextField fx:id="rpeTextField" promptText="RPE (e.g. 8)" prefWidth="100"/>
                <TextField fx:id="bodyweightTextField" promptText="Bodyweight (kg)" prefWidth="120"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <DatePicker fx:id="liftDateDatePicker" promptText="Lift Date" prefWidth="150"/>
                <TextField fx:id="notesTextField" promptText="Notes" prefWidth="250"/>
                <CheckBox fx:id="milestoneCheckBox" text="Milestone"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="addRecordButton" onAction="#newPersonalRecord" text="Add Record"/>
                <Button fx:id="editRecordButton" onAction="#editPersonalRecord" text="Save Changes"/>
            </HBox>
        </VBox>

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="backupButton" onAction="#backupDatabase" text="Backup Database"/>
            <Button fx:id="restoreButton" onAction="#restoreDatabase" text="Restore Database"/>
        </HBox>
    </children>
</VBox>
