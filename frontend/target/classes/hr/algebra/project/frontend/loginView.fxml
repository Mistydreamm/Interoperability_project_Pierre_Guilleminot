<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.project.frontend.controller.LoginRequestController">
   <children>
      <TextField fx:id="username" layoutX="38.0" layoutY="39.0" promptText="Username" />
      <TextField fx:id="email" layoutX="38.0" layoutY="87.0" promptText="Email Address" visible="false" />
      <PasswordField fx:id="password" layoutX="38.0" layoutY="87.0" promptText="Password" />

      <Button fx:id="LoginButton" layoutX="38.0" layoutY="149.0" onAction="#onLoginAction" text="LOGIN" />
      <Label fx:id="toggleModeLabel" layoutX="38.0" layoutY="200.0" onMouseClicked="#onToggleMode" text="Don't have an account? Register" textFill="BLUE" underline="true" style="-fx-cursor: hand;" />

      <Label fx:id="statusLabel" layoutX="219.0" layoutY="280.0" text="" textFill="RED" />
   </children>
</AnchorPane>
